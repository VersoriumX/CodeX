<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VersoriumX Technology Inc - Price Watcher</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/web3/dist/web3.min.js"></script>
    <script src="https://unpkg.com/web3modal"></script>
    <style>
        body {
            background-color: #000;
            color: #fff;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
            width: 600px;
            border: 1px solid #444;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
        }
        h2 {
            text-align: center;
        }
        canvas {
            max-width: 100%;
            height: 300px;
        }
        #walletButton {
            display: block;
            margin: 20px auto;
            padding: 10px 20px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            text-align: center;
        }
        #walletButton:hover {
            background-color: #0056b3;
        }
        #searchContainer {
            margin: 20px 0;
        }
        #searchInput {
            width: calc(100% - 22px);
            padding: 10px;
            border: 1px solid #444;
            border-radius: 5px;
            background-color: #222;
            color: white;
        }
        #searchResults {
            margin-top: 10px;
            list-style-type: none;
            padding: 0;
        }
        #searchResults li {
            margin: 5px 0;
        }
        #searchResults a {
            color: #007bff;
            text-decoration: none;
        }
        #searchResults a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <h2>VersoriumX Technology Inc</h2>
    <h3>Price Watcher</h3>
    
    <div id="searchContainer">
        <input type="text" id="searchInput" placeholder="Search...">
        <ul id="searchResults"></ul>
    </div>

    <canvas id="metalChart"></canvas>
    <canvas id="cryptoChart"></canvas>
    <button id="walletButton">Connect Wallet</button>
    <div id="walletAddress" style="text-align: center; margin-top: 10px;"></div>

    <div style="text-align: center; margin-top: 20px;">
        <a href="https://finance.yahoo.com/quote/AAPL" target="_blank" style="color: #007bff;">View Apple Stock</a><br>
        <a href="https://www.metals-api.com/" target="_blank" style="color: #007bff;">Current US Spot Gold Prices</a>
    </div>

    <script>
        const metals = {
            gold: { color: 'gold', symbol: 'XAU' },
            platinum: { color: 'plum', symbol: 'XPT' },
            silver: { color: 'silver', symbol: 'XAG' },
            nickel: { color: 'lightblue', symbol: 'NICKEL' },
            copper: { color: 'brown', symbol: 'COPPER' }
        };

        const cryptos = {
            bitcoin: { color: 'orange', symbol: 'BTC' },
            ethereum: { color: 'blue', symbol: 'ETH' },
            ethereumX: { color: 'green', symbol: 'ETHX' }
        };

        const ctxMetals = document.getElementById('metalChart').getContext('2d');
        const ctxCryptos = document.getElementById('cryptoChart').getContext('2d');

        const metalDatasets = Object.keys(metals).map(metal => ({
            label: metal.charAt(0).toUpperCase() + metal.slice(1),
            borderColor: metals[metal].color,
            backgroundColor: metals[metal].color,
            data: [],
            fill: false,
            tension: 0.1
        }));

        const cryptoDatasets = Object.keys(cryptos).map(crypto => ({
            label: crypto.charAt(0).toUpperCase() + crypto.slice(1),
            borderColor: cryptos[crypto].color,
            backgroundColor: cryptos[crypto].color,
            data: [],
            fill: false,
            tension: 0.1
        }));

        const metalChart = new Chart(ctxMetals, {
            type: 'line',
            data: {
                labels: [],
                datasets: metalDatasets
            },
            options: {
                responsive: true,
                scales: {
                    x: {
                        type: 'linear',
                        position: 'bottom'
                    },
                    y: {
                        beginAtZero: false
                    }
                }
            }
        });

        const cryptoChart = new Chart(ctxCrypt)
